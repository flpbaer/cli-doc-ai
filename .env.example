# Copy this file to .env and fill in your values
# Bun loads .env automatically — no extra packages needed

# Optional: which AI provider to use. If unset, the CLI asks interactively.
#   openrouter — cloud, needs OPENROUTER_API_KEY (default)
#   ollama     — local server, no API key
AI_PROVIDER=openrouter

# ─── OpenRouter ────────────────────────────────────────────────────────────

# Required (if using OpenRouter): your OpenRouter API key
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional: override the default model (default is free)
# Free options:
#   meta-llama/llama-3.3-70b-instruct:free
#   meta-llama/llama-3.2-3b-instruct:free
#   nvidia/nemotron-nano-9b-v2:free
#   qwen/qwen3-coder:free
# Paid options:
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─── Ollama (local) ────────────────────────────────────────────────────────

# Optional: only used when AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# ─── Output ────────────────────────────────────────────────────────────────

# Optional: language for generated files. If unset, the CLI asks interactively.
#   en    — English (default)
#   pt-BR — Português (Brasil)
# DOC_LANGUAGE=en
